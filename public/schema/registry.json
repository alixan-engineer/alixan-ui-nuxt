{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://nuxt.ui.alixan.kz/schema/registry.json",
	"title": "Alixan UI Nuxt Registry",
	"type": "object",
	"required": ["components"],
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"components": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "title", "description"],
				"additionalProperties": false,
				"properties": {
					"name": {
						"type": "string",
						"pattern": "^[a-z0-9-]+$"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					}
				}
			}
		}
	}
}
